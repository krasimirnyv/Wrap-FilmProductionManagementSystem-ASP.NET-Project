# ═══════════════════════════════════════════════════════════════
#  .env.example - safe for git commit
#
#  Copy this file as an .env and fill in the actual values:
#    cp .env.example .env
#
#  .env is in .gitignore and should NEVER be committed!
# ═══════════════════════════════════════════════════════════════

# SQL Server Port

MSSQL_PORT=1434

# SQL Server SA Password
# Requirements: minimum of 8 characters with at least 1 upper case and 1 lower case letter, 1 digit and 1 special symbol in it.

MSSQL_SA_PASSWORD=YourStrong@Passw0rd_CHANGE_ME

# Name of the database

DB_NAME=WrapDb

# Connection string

ConnectionStrings__DockerConnection=Server=localhost,1434;Database=WrapDb;User Id=sa;Password=YourRealStrongPasswordHere!;Encrypt=true;TrustServerCertificate=True;