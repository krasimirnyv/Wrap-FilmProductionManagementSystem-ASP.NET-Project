# ═══════════════════════════════════════════════════════════════
#  .env.example - safe for git commit
#
#  Copy this file as .env and fill in the real values:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# SQL Edge host port
MSSQL_PORT=1434

# SQL Edge SA password
MSSQL_SA_PASSWORD=YourStrong@Passw0rd_CHANGE_ME

# Database name
DB_NAME=WrapDb

# Connection string used by the web container
ConnectionStrings__MyDevConnection=Server=sql_project,1433;Database=WrapDb;User Id=sa;Password=YourStrong@Passw0rd_CHANGE_ME;Encrypt=true;TrustServerCertificate=true;
