@using Wrap.Infrastructure.Utilities.Interfaces;

@model AllProductionsIndexViewModel

@inject ISlugGenerator SlugGenerator;

@{
    ViewData[TitleDataKey] = "Productions";
}

@section Styles {
    <link rel="stylesheet" href="~/css/production.css" asp-append-version="true" />
}

<div class="production-wrapper">
    <div class="container">

        <partial name="_TempDataPartial"></partial>

        @* ── Page Header ── *@
        <div class="production-header-card d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="fw-bold mb-1" style="color: var(--wrap-dark-blue);">
                    <i class="bi bi-camera-reels me-2" style="color: var(--wrap-blue);"></i>All Productions
                </h1>
                <p class="text-muted mb-0">Browse and manage your film productions</p>
            </div>
            <a asp-area="" asp-controller="Production" asp-action="Create" class="btn btn-production">
                <i class="bi bi-plus-circle me-2"></i>New Production
            </a>
        </div>

        @* ── Search Bar ── *@
        <div class="section-card py-3 px-4">
            <div class="row g-2 align-items-center">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text"
                              style="border-color: var(--wrap-blue); color: var(--wrap-blue);">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control"
                               placeholder="Search by production's title…" />
                    </div>
                </div>
                
                @* ── Filter Bar ── *@
                <div class="col-md-2">
                    <select id="statusFilter" class="form-select">
                        <option value="">All Phases</option>
                        <option value="Pre-production">Pre-production</option>
                        <option value="Production">Production</option>
                        <option value="Post-production">Post-production</option>
                        <option value="Distribution">Distribution</option>
                    </select>
                </div>
                
                @* ── Pagination ── *@
                <div class="col-md-4 d-flex justify-content-end align-items-center gap-3">
                    <span class="text-muted small"
                          id="resultsCount"
                          data-total="@Model.TotalCount">
                        @Model.Count of @Model.TotalCount @(Model.TotalCount == 1 ? "production" : "productions")
                    </span>

                    <partial name="_ProductionsPaginationPartial" model="Model" />
                </div>
            </div>
        </div>

        @* ── Grid ── *@
        @if (!Model.Productions.Any())
        {
            <div class="section-card mt-4">
                <div class="empty-state">
                    <i class="bi bi-film"></i>
                    <p class="mt-2">No productions yet. Create your first one!</p>
                    <a asp-area="" asp-controller="Production" asp-action="Create" class="btn btn-production mt-3">
                        <i class="bi bi-plus-circle me-2"></i>Create Your Production
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="row mt-4" id="productionsGrid">
                @foreach (ProductionViewModel production in Model.Productions)
                {
                    <div class="col-md-4 col-sm-6 mb-4 prod-grid-item"
                         data-title="@production.Title"
                         data-status="@production.StatusType">
                        <div class="prod-card">
                            <img src="@production.ThumbnailPath"
                                 class="prod-card-img"
                                 alt="@production.Title">

                            <div class="prod-card-body">
                                <h5 class="prod-card-title">@production.Title</h5>
                                <span class="status-badge @production.StatusAbstractClass">
                                    @GetDisplayName(production.StatusType)
                                </span>
                            </div>

                            <div class="prod-card-footer justify-content-end">
                                <a asp-area="" asp-controller="Production" asp-action="Details" asp-route-productionId="@production.Id" 
                                   asp-route-slug="@SlugGenerator.GenerateSlug(production.Title)"
                                   class="btn-icon-sm btn-icon-view" title="View"> Details
                                    <i class="bi bi-eye-fill"></i>
                                </a>
                                <a asp-area="" asp-controller="Production" asp-action="Edit" asp-route-productionId="@production.Id" 
                                   asp-route-slug="@SlugGenerator.GenerateSlug(production.Title)"
                                   class="btn-icon-sm btn-icon-edit" title="Edit">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center py-4 d-none" id="noResults">
                <div class="section-card d-inline-block px-5">
                    <div class="empty-state">
                        <i class="bi bi-search"></i>
                        <p>No productions match your search.</p>
                    </div>
                </div>
            </div>
            
            <div class="d-flex justify-content-center mt-2 mb-4" id="bottomPaginationWrap">
                <partial name="_ProductionsPaginationPartial" model="Model" />
            </div>
        }

    </div>
</div>

@section Scripts {
    <script src="~/js/production/production-index.js" asp-append-version="true"></script>
}
